{
  "$schema": "https://raw.githubusercontent.com/nicegui/tauri2-schema/main/tauri.conf.json",
  "productName": "Voice",
  "version": "0.1.0",
  "identifier": "com.voice.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev:frontend",
    "beforeBuildCommand": "npm run build:frontend"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Voice",
        "width": 1,
        "height": 1,
        "x": -100,
        "y": -100,
        "resizable": false,
        "alwaysOnTop": false,
        "decorations": false,
        "transparent": true,
        "skipTaskbar": true,
        "visible": true,
        "center": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; media-src 'self' mediastream:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "Speak and type anywhere — local voice dictation",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0", "libayatana-appindicator3-1"]
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "global-shortcut": null
  }
}
